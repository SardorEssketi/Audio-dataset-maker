# Audio Pipeline Web App Configuration (example)
#
# Copy values into a local `.env` (this repo ignores `.env`).
# Do NOT commit real secrets to GitHub.

# API Configuration
SECRET_KEY=change_me_to_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Public domain (used by reverse proxy / TLS)
DOMAIN=example.com

# Pipeline Limits
MAX_CONCURRENT_JOBS=3
MAX_USER_CONCURRENT=1
MAX_INPUT_SIZE_MB=2048
MAX_FILE_COUNT=5

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Config Encryption Key (optional, defaults to SECRET_KEY)
CONFIG_ENCRYPTION_KEY=optional_separate_key_or_leave_blank
